{
  // ── Spell checker ────────────────────────────────────────────────────────
  "cSpell.words": [
    "accum",
    "accums",
    "addgroup",
    "adduser",
    "anyhow",
    "Bitmask",
    "bpid",
    "btreeindex",
    "bubbletea",
    "byteorder",
    "catalogdb",
    "catalogio",
    "catalogmanager",
    "catalogreader",
    "charmbracelet",
    "checkpointing",
    "checksumming",
    "CKPT",
    "clippy",
    "closedb",
    "codegen",
    "concurrentdb",
    "Condvar",
    "costmodel",
    "cref",
    "crossbeam",
    "crossterm",
    "Deque",
    "Equi",
    "Equijoin",
    "evictable",
    "façade",
    "Fanout",
    "Freqs",
    "functools",
    "hashbrown",
    "hashindex",
    "heapage",
    "heapreader",
    "impls",
    "indexmanager",
    "indexonlyscan",
    "indexops",
    "indexscan",
    "Inited",
    "inotify",
    "inotifywait",
    "installsuffix",
    "lerr",
    "lipgloss",
    "Lparen",
    "lsns",
    "mcvs",
    "mitranim",
    "MVCC",
    "mydb",
    "nopk",
    "pageid",
    "parkng",
    "peekable",
    "permdb",
    "pgdn",
    "pgdown",
    "pgup",
    "pids",
    "pkey",
    "preds",
    "proptest",
    "Ptrs",
    "pushdown",
    "RAII",
    "ratatui",
    "reaccess",
    "rerr",
    "roundtrips",
    "Rparen",
    "RUSTSEC",
    "selectivities",
    "seqscan",
    "serde",
    "setops",
    "siphasher",
    "statsdb",
    "storemy",
    "systable",
    "systemtable",
    "tablecache",
    "tempfile",
    "testcache",
    "testdb",
    "testutil",
    "thiserror",
    "tids",
    "tndata",
    "tracing",
    "tsch",
    "Txns",
    "unflushed"
  ],

  // ── Rust Analyzer ────────────────────────────────────────────────────────
  "rust-analyzer.linkedProjects": ["db/Cargo.toml"],

  // Use clippy instead of cargo check — catches more issues
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.check.extraArgs": [
    "--",
    "-W",
    "clippy::pedantic",
    "-A",
    "clippy::must_use_candidate",
    "-A",
    "clippy::missing_errors_doc",
    "-A",
    "clippy::missing_panics_doc"
  ],

  // Inlay hints — show types, lifetimes, param names inline
  "rust-analyzer.inlayHints.typeHints.enable": true,
  "rust-analyzer.inlayHints.chainingHints.enable": true,
  "rust-analyzer.inlayHints.parameterHints.enable": true,
  "rust-analyzer.inlayHints.lifetimeElisionHints.enable": "skip_trivial",
  "rust-analyzer.inlayHints.closureReturnTypeHints.enable": "with_block",
  "rust-analyzer.inlayHints.bindingModeHints.enable": true,
  "rust-analyzer.inlayHints.discriminantHints.enable": "fieldless",
  "rust-analyzer.inlayHints.expressionAdjustmentHints.enable": "reborrow",

  // Completions
  "rust-analyzer.completion.autoimport.enable": true,
  "rust-analyzer.completion.postfix.enable": true,
  "rust-analyzer.completion.privateEditable.enable": true,

  // Show documentation on hover
  "rust-analyzer.hover.documentation.enable": true,
  "rust-analyzer.hover.documentation.keywords.enable": true,
  "rust-analyzer.hover.actions.enable": true,
  "rust-analyzer.hover.actions.run.enable": true,
  "rust-analyzer.hover.actions.debug.enable": true,
  "rust-analyzer.hover.actions.references.enable": true,
  "rust-analyzer.hover.actions.implementations.enable": true,

  // Proc macro support (needed for thiserror, etc.)
  "rust-analyzer.procMacro.enable": true,

  // Use nightly rustfmt for format-on-save — rustfmt.toml uses unstable options
  // (imports_granularity, group_imports, wrap_comments, ...). Stable rustfmt
  // silently ignores them, so we pin the same nightly as Makefile/CI.
  "rust-analyzer.rustfmt.overrideCommand": [
    "rustup",
    "run",
    "nightly-2026-04-01",
    "rustfmt",
    "--edition=2024"
  ],

  // Cargo features
  "rust-analyzer.cargo.allFeatures": true,
  "rust-analyzer.cargo.buildScripts.enable": true,

  // Separate target dir for rust-analyzer. Without this, RA and `cargo build`
  // from the terminal fight over target/ — each invalidates the other's cache,
  // and every save triggers a full recompile. Combined with the opt-level=2
  // deps profile in .cargo/config.toml, sharing target/ would be painful.
  "rust-analyzer.cargo.targetDir": true,

  // Show errors from all crates in workspace
  "rust-analyzer.diagnostics.enable": true,
  "rust-analyzer.diagnostics.experimental.enable": true,

  // Semantic highlighting
  "rust-analyzer.semanticHighlighting.strings.enable": true,
  "rust-analyzer.highlighting.strings": true,
  "editor.semanticHighlighting.enabled": true,
  "files.associations": {
    "*.rs": "rust"
  },

  // ── Editor ───────────────────────────────────────────────────────────────
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.formatOnSave": true,
    "editor.formatOnType": false,
    "editor.semanticHighlighting.enabled": true,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.rulers": [100],
    "editor.wordWrap": "off"
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml",
    "editor.formatOnSave": true
  },

  // ── Python / storemy-viz ────────────────────────────────────────────────
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit",
      "source.fixAll": "explicit",
      "source.fixAll.ruff": "explicit"
    },
    "editor.rulers": [100]
  },

  // Prefer ruff for linting/formatting in Python
  "ruff.enable": true,
  "ruff.organizeImports": true,

  // Python language server / analysis
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.inlayHints.functionReturnTypes": true,
  "python.analysis.inlayHints.variableTypes": true,

  // Testing (works well for tools/viz)
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": ["-q"],

  // Keep explorer/search clean
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/.venv": true,
    "**/.venv*": true,
    "**/dist": true,
    "**/build": true,
    "**/*.egg-info": true
  },

  // Error Lens — show errors/warnings inline at end of line
  "errorLens.enabledDiagnosticLevels": ["error", "warning", "info"],
  "errorLens.gutterIconsEnabled": true,
  "errorLens.delay": 300,

  // ── TypeScript / React ───────────────────────────────────────────────────
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": true,
    "editor.rulers": [100],
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "vscode.typescript-language-features",
    "editor.formatOnSave": true,
    "editor.rulers": [100],
    "editor.tabSize": 2,
    "editor.insertSpaces": true
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true,
    "editor.tabSize": 2
  },

  // TypeScript language server
  "typescript.inlayHints.parameterNames.enabled": "literals",
  "typescript.inlayHints.parameterTypes.enabled": false,
  "typescript.inlayHints.variableTypes.enabled": false,
  "typescript.inlayHints.returnTypes.enabled": true,
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.suggest.autoImports": true,
  "typescript.preferences.importModuleSpecifier": "relative",
  "typescript.preferences.quoteStyle": "double",
  "javascript.preferences.quoteStyle": "double",

  // Tailwind CSS IntelliSense (v4 uses CSS-first config, not tailwind.config.js)
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
    ["cn\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"]
  ],
  "tailwindCSS.includeLanguages": {
    "typescriptreact": "html"
  },

  // ── Debugger (CodeLLDB) ───────────────────────────────────────────────────
  "lldb.displayFormat": "auto",
  "lldb.showDisassembly": "never",
  "lldb.dereferencePointers": true,

  // ── Test Explorer ────────────────────────────────────────────────────────
  "rust-analyzer.runnables.extraArgs": ["--", "--nocapture"],
  "rust-analyzer.runnables.extraTestBinaryArgs": ["--nocapture"]
}
