{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Rust: Build (debug)",
            "type": "shell",
            "command": "cargo",
            "args": ["build"],
            "options": { "cwd": "${workspaceFolder}/db" },
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "shared", "clear": true },
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "Rust: Build (release)",
            "type": "shell",
            "command": "cargo",
            "args": ["build", "--release"],
            "options": { "cwd": "${workspaceFolder}/db" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "clear": true },
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "Rust: Test All",
            "type": "shell",
            "command": "cargo",
            "args": ["test", "--", "--nocapture"],
            "options": { "cwd": "${workspaceFolder}/db" },
            "group": { "kind": "test", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "shared", "clear": true },
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "Rust: Clippy",
            "type": "shell",
            "command": "cargo",
            "args": [
                "clippy", "--all-targets", "--",
                "-W", "clippy::pedantic",
                "-A", "clippy::must_use_candidate",
                "-A", "clippy::missing_errors_doc",
                "-A", "clippy::missing_panics_doc"
            ],
            "options": { "cwd": "${workspaceFolder}/db" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "clear": true },
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "Rust: Check",
            "type": "shell",
            "command": "cargo",
            "args": ["check", "--all-targets"],
            "options": { "cwd": "${workspaceFolder}/db" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "clear": true },
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "Rust: Doc",
            "type": "shell",
            "command": "cargo",
            "args": ["doc", "--no-deps", "--open"],
            "options": { "cwd": "${workspaceFolder}/db" },
            "group": "none",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "Rust: Bench",
            "type": "shell",
            "command": "cargo",
            "args": ["bench"],
            "options": { "cwd": "${workspaceFolder}/db" },
            "group": "test",
            "presentation": { "reveal": "always", "panel": "shared", "clear": true },
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "Rust: Watch (cargo-watch)",
            "type": "shell",
            "command": "cargo",
            "args": ["watch", "-x", "check", "-x", "test"],
            "options": { "cwd": "${workspaceFolder}/db" },
            "group": "none",
            "isBackground": true,
            "presentation": { "reveal": "always", "panel": "dedicated" },
            "problemMatcher": ["$rustc"]
        },
        {
            "label": "Rust: Expand Macros",
            "type": "shell",
            "command": "cargo",
            "args": ["expand"],
            "options": { "cwd": "${workspaceFolder}/db" },
            "group": "none",
            "presentation": { "reveal": "always", "panel": "shared", "clear": true },
            "problemMatcher": []
        }
    ]
}
